<!DOCTYPE html>
<html lang="{{ site.lang | default: "ja" }}">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <link rel="icon" type="image/jpg" href="https://raw.githubusercontent.com/Kfox-official/takes_db/refs/heads/main/icon.jpg">
    <title>{{ page.title | default: site.title }}</title>
    
    <style>
        /* ========================================== */
        /* 論文・インデックス共通：サイバーダークテーマ */
        /* ========================================== */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", sans-serif;
            line-height: 1.75;
            color: #c9d1d9; /* 明るいグレー */
            background-color: #0d1117; /* 漆黒 */
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        h1 { font-size: 2.2rem; border-bottom: 2px solid #21262d; padding-bottom: 0.4em; color: #f0f6fc; }
        h2 { font-size: 1.6rem; border-bottom: 1px solid #21262d; padding-bottom: 0.3em; margin-top: 40px; color: #f0f6fc; }
        h3 { font-size: 1.2rem; color: #f0f6fc; margin-top: 30px; }
        hr { height: 1px; padding: 0; margin: 30px 0; background-color: #21262d; border: 0; }
        ul, ol { padding-left: 2em; }
        li { margin-top: 0.3em; }
        strong { color: #ff79c6; } /* 重要な文字はたけピンク */
        blockquote {
            margin: 1.5em 0;
            padding: 0 1em;
            color: #8b949e;
            border-left: 0.25em solid #ff79c6;
            background-color: #161b22;
            border-radius: 4px;
        }
        
        /* リンクカラー */
        a { color: #58a6ff; text-decoration: none; font-weight: bold; }
        a:hover { text-decoration: underline; color: #ff79c6; }
        
        /* テーブル（目次など用）のデザイン */
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { padding: 12px; border: 1px solid #30363d; text-align: left; }
        th { background-color: #161b22; color: #f0f6fc; }
        
        .footer { text-align: center; margin-top: 60px; color: #8b949e; font-size: 0.85em; border-top: 1px solid #21262d; padding-top: 20px; }
    </style>
</head>
<body>

    <div class="wrapper">
        <section>
            {{ content }}
        </section>
    </div>

    <div class="footer">
        © 2026 Takes DB Project. All Rights Reserved.
    </div>

    <script src="{{ '/assets/js/scale.fix.js' | relative_url }}"></script>
</body>
</html>
